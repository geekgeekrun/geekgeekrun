{
  "name": "@geekgeekrun/sqlite-plugin",
  "version": "0.0.2",
  "description": "",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./handlers": {
      "require": "./dist/handlers.js",
      "import": "./dist/handlers.js",
      "types": "./dist/handlers.d.ts"
    },
    "./enums": {
      "require": "./dist/enums.js",
      "import": "./dist/enums.js",
      "types": "./dist/enums.d.ts"
    },
    "./entity/*": {
      "require": "./dist/entity/*.js",
      "import": "./dist/entity/*.js",
      "types": "./dist/entity/*.d.ts"
    },
    "./utils/*": {
      "require": "./dist/utils/*.js",
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    },
    "./src/entity/*": {
      "require": "./dist/entity/*.js",
      "import": "./dist/entity/*.js",
      "types": "./dist/entity/*.d.ts"
    },
    "./src/utils/*": {
      "require": "./dist/utils/*.js",
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    },
    "./src/enums": {
      "require": "./dist/enums.js",
      "import": "./dist/enums.js",
      "types": "./dist/enums.d.ts"
    }
  },
  "dependencies": {
    "better-sqlite3": "12.6.2",
    "cli-highlight": "^2.1.11",
    "lodash": "^4.17.21",
    "reflect-metadata": "^0.2.1",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.23",
    "node-gyp": "^12.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "dev": "rimraf dist && tsc --outDir dist --watch true",
    "build": "rimraf dist && tsc --outDir dist",
    "postinstall": "npm run build || exit 0;"
  }
}
