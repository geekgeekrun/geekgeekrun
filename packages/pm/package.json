{
  "name": "@geekgeekrun/pm",
  "version": "0.0.1",
  "description": "Electron多进程架构",
  "main": "dist/daemon.js",
  "exports": {
    ".": {
      "require": "./dist/daemon.js",
      "import": "./dist/daemon.js",
      "types": "./dist/daemon.d.ts"
    },
    "./daemon": {
      "require": "./dist/daemon.js",
      "import": "./dist/daemon.js",
      "types": "./dist/daemon.d.ts"
    },
    "./daemon.js": {
      "require": "./dist/daemon.js",
      "import": "./dist/daemon.js",
      "types": "./dist/daemon.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start:daemon": "electron ./dist/daemon",
    "dev:daemon": "electron ./dist/daemon --dev",
    "start:worker": "electron ./dist/worker",
    "dev:worker": "electron ./dist/worker --dev"
  },
  "keywords": [
    "electron",
    "multi-process"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "28.2.0",
    "typescript": "^5.6.2",
    "@types/node": "^20.16.10"
  },
  "dependencies": {
    "JSONStream": "^1.3.5",
    "split2": "^4.2.0"
  }
}
